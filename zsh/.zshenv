# put zsh state files in XDG state directory
export HISTFILE="$XDG_STATE_HOME/zsh/history"

# move vimrc to XDG config directory
export MYVIMRC="$XDG_CONFIG_HOME/vim/vimrc"

# set tldr config to XDG Base Dir spec
export TLRC_CONFIG="$XDG_CONFIG_HOME/tldr"

# Set the less history file to the XDG state directory
export LESSHISTFILE="$XDG_STATE_HOME/less/.lesshst"
